name = "mouse-oj"
main = "src/index.js"
compatibility_date = "2026-06-16"

[assets]
directory = "./frontend/dist"
not_found_handling = "single-page-application"

[[d1_databases]]
binding = "DB"
database_name = "mouse-oj-db"
database_id = "your-d1-database-id-here"

[vars]
JWT_SECRET = "your-jwt-secret-here"
# Vjudge Cookie 用 secret 注入，不写在这里：
#   npx wrangler secret put VJUDGE_COOKIE

[observability]
enabled = false
